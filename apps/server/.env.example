# Postgres (Prisma). Ajuste para a sua instância.
DATABASE_URL="postgresql://talkhub:talkhub@localhost:5432/talkhub?schema=public"

# Servidor (REST Fastify + realtime Colyseus na mesma porta)
PORT=2567
HOST=0.0.0.0

# Sessão (JWT). TROQUE em produção.
JWT_SECRET="dev-insecure-secret-change-me"

# Front-end (para redirecionar após o OAuth)
WEB_URL="http://localhost:5173"

# Google OAuth (opcional; login de convidado funciona sem isto)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:2567/auth/google/callback"
